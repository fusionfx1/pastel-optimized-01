---
const aprMin = import.meta.env.PUBLIC_APRMIN || '${aprMin}';
const aprMax = import.meta.env.PUBLIC_APRMAX || '${aprMax}';
const phone  = import.meta.env.PUBLIC_PHONE  || '${phone}';

const faqs = [
  {
    q: 'Does checking my payment options damage my credit score?',
    a: 'No. The approval check uses a soft inquiry only—identical to the inquiry used when you check your own credit report. Soft inquiries do not appear on credit reports viewed by lenders and have zero impact on your credit score. You can review all available payment plans with complete safety.',
  },
  {
    q: 'What are the 0% APR options, and how do I qualify?',
    a: 'Select payment plans carry 0% APR for shorter terms (typically 3-6 months), meaning you repay exactly the amount financed with zero interest charges. Qualification depends on credit profile and the plan term you select. If you qualify for 0% financing, it will appear in your plan options—clearly labeled with the rate, term, and total cost.',
  },
  {
    q: 'What veterinary procedures can I finance with Scratchpay?',
    a: 'Scratchpay payment plans cover all veterinary services at participating clinics: emergency care, diagnostics, surgery, dental work, specialist consultations, oncology treatment, orthopedic procedures, preventive care, and prescription medications. If your vet accepts Scratchpay, any service they provide can be financed.',
  },
  {
    q: 'How fast is the approval and confirmation process?',
    a: 'Approval decisions return in 60 seconds. Once you select your preferred plan, confirmation happens instantly through the clinic\'s integrated system—no paperwork, no faxing, no delays. Your veterinarian can begin treatment immediately after your plan is confirmed.',
  },
  {
    q: 'What credit profile is required to get approved?',
    a: 'Scratchpay approves a wide range of credit profiles, including applicants with limited or imperfect credit history. The approval algorithm considers your current financial capacity—not just past credit events. Credit score is one factor among several. Income, employment stability, and overall financial picture all influence your available plans.',
  },
  {
    q: `What interest rates does Scratchpay offer?`,
    a: `Payment plan APRs range from ${aprMin}% to ${aprMax}%, depending on credit profile and term length. Your specific rate is fixed—meaning it never changes—and disclosed in full before you confirm. Every plan shows the APR, monthly payment, and total cost upfront. No surprises, no rate adjustments, no variable pricing.`,
  },
  {
    q: 'Are there hidden fees or application charges?',
    a: 'No application fees. No origination fees. No hidden charges. The total cost you will repay—including any applicable fees—is disclosed completely before you confirm your plan selection. What you see is what you pay.',
  },
  {
    q: 'Can I pay off my balance early without penalty?',
    a: 'Yes. Zero prepayment penalties. Pay ahead or pay in full anytime without fees or restrictions. Early repayment reduces total interest charges because interest accrues only on the outstanding principal balance.',
  },
  {
    q: 'What if my veterinarian doesn\'t accept Scratchpay?',
    a: 'Scratchpay partners with over 28,000 veterinary clinics nationwide. If your clinic is not yet enrolled, they can apply for free at the Scratchpay website—approval typically takes 1-2 business days. You can also use the clinic locator to find Scratchpay-accepting practices near you.',
  },
  {
    q: 'How is Scratchpay different from using a credit card?',
    a: 'Credit cards carry revolving balances with variable APRs (averaging 22-27% nationally) and minimum payments that extend repayment for years. Scratchpay offers fixed-term payment plans with predictable monthly payments, disclosed total costs, and 0% APR options. You know the exact amount and timeline before you commit—and the terms never change.',
  },
];
---

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
})} />

<section id="faq" class="py-20 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="grid md:grid-cols-[380px_1fr] gap-14 items-start">
      <!-- Left: sticky -->
      <div class="md:sticky md:top-24">
        <span class="section-label">Payment Plans—Answered Clearly</span>
        <h2 class="section-title">Common Questions</h2>
        <p class="text-foreground/70 text-base leading-relaxed mb-8">
          Direct answers to the questions pet owners ask before checking their financing options. If your question isn't covered here, reach us by phone.
        </p>

        <div class="glass-card p-5 flex gap-4 items-center">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
            style="background: hsl(38 62% 58% / 0.1);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="hsl(38 62% 58%)" stroke-width="2" stroke-linecap="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.12 19.79 19.79 0 012 2.44 2 2 0 014 .4h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 8.15a16 16 0 006.29 6.29l1.01-1.01a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="text-foreground/70 text-sm font-semibold">Still have questions?</p>
            <p class="text-foreground/65 text-xs mt-0.5">{phone} · Mon–Fri 8am–8pm EST</p>
          </div>
        </div>
      </div>

      <!-- Right: accordion -->
      <div id="faq-list">
        {faqs.map((faq, i) => (
          <div class={`faq-item ${i === 0 ? 'open' : ''}`} data-index={i}>
            <button class="faq-trigger">
              <span>{faq.q}</span>
              <span class="faq-icon">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
                  <path d="M12 5v14M5 12h14"/>
                </svg>
              </span>
            </button>
            <div class="faq-content">
              {faq.a}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const faqList = document.getElementById('faq-list');
  if (faqList) {
    faqList.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement).closest('.faq-trigger');
      if (!trigger) return;
      const item = trigger.closest('.faq-item');
      if (!item) return;
      const isOpen = item.classList.contains('open');
      faqList.querySelectorAll('.faq-item').forEach(el => el.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  }
</script>
