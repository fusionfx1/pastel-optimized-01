---
const aprMin = import.meta.env.PUBLIC_APRMIN || '${aprMin}';
const aprMax = import.meta.env.PUBLIC_APRMAX || '${aprMax}';
const phone  = import.meta.env.PUBLIC_PHONE  || '${phone}';

const faqs = [
  {
    q: 'Will checking my rate affect my credit score?',
    a: 'Checking your rate triggers a soft inquiry, which lenders and bureaus treat differently from a credit application — it leaves no mark on your score. A hard inquiry only occurs if you choose to move forward with a specific lender offer and authorize a full application.',
  },
  {
    q: 'How quickly will the money reach my bank account?',
    a: 'After you sign your loan agreement, most lenders in our network initiate the transfer within hours. The funds typically appear in your account the next business morning. Applications completed and signed before 2pm EST on a business day have the highest likelihood of same-day or next-morning funding.',
  },
  {
    q: 'What can I use the installment loan for?',
    a: 'Borrowers on our platform commonly use funds for debt consolidation, medical and dental bills, car repairs, home maintenance, moving expenses, and other planned or unexpected costs. Each lender sets its own acceptable use policy, which will be outlined in your loan agreement prior to signing.',
  },
  {
    q: 'Can I pay off my loan before the term ends?',
    a: 'Yes, and it costs you nothing extra. Paying off your balance early reduces the total interest you owe because interest is calculated on the remaining principal. There are no prepayment penalties on any loan offered through our marketplace.',
  },
  {
    q: 'What credit score is required to apply?',
    a: 'Lenders in our network consider applicants with credit scores starting at 560. Your score is one factor among several — income stability, existing debt obligations, and employment history also influence the offer you receive. Applicants who are rebuilding credit are welcome to apply.',
  },
  {
    q: 'How is my APR determined?',
    a: `Lenders calculate your rate based on your credit score, verifiable income, the loan amount you request, and the repayment term you choose. Rates through our marketplace range from ${aprMin}% to ${aprMax}% APR. The rate presented in your offer is the rate locked into your agreement — it does not change after you sign.`,
  },
  {
    q: 'Are there origination or application fees?',
    a: 'Many lenders in our network charge no origination fee. When a fee does apply, it is stated clearly in the loan terms before you accept any offer. We do not charge application fees and do not add fees on our end — any cost you see comes directly from the lender and is disclosed before you commit.',
  },
  {
    q: 'How do fixed monthly payments work?',
    a: 'Your payment amount is set at closing and stays the same for every month of your loan term. Most lenders collect payments via ACH debit from your bank account on a date you confirm when you sign. You receive a complete amortization schedule showing exactly how each payment divides between principal and interest.',
  },
  {
    q: 'What happens if my application is not approved?',
    a: 'If no lender in our network is able to extend an offer based on your current profile, you will receive a clear notification. We encourage you to review your credit report for any errors, reduce existing balances if possible, and reapply when your financial picture has improved. There is no penalty for applying.',
  },
  {
    q: 'How does a loan marketplace differ from a direct lender?',
    a: 'A direct lender funds the loan itself. A marketplace like ours connects you to a network of independent lenders and presents you with the offers they generate based on your profile. You choose which offer to accept — or none. This means you can compare multiple options in one place without submitting separate applications to each lender.',
  },
];
---

<section id="faq" class="py-20 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="grid md:grid-cols-[380px_1fr] gap-14 items-start">
      <!-- Left: sticky -->
      <div class="md:sticky md:top-24">
        <span class="section-label">Common Questions</span>
        <h2 class="section-title">Frequently Asked Questions</h2>
        <p class="text-foreground/70 text-base leading-relaxed mb-8">
          Straight answers to the questions most borrowers ask before they apply. If something is not covered here, our team is available by phone.
        </p>

        <div class="glass-card p-5 flex gap-4 items-center">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
            style="background: hsl(38 62% 58% / 0.1);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="hsl(38 62% 58%)" stroke-width="2" stroke-linecap="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.12 19.79 19.79 0 012 2.44 2 2 0 014 .4h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 8.15a16 16 0 006.29 6.29l1.01-1.01a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="text-foreground/70 text-sm font-semibold">Still have questions?</p>
            <p class="text-foreground/65 text-xs mt-0.5">{phone} · Mon–Fri 8am–8pm EST</p>
          </div>
        </div>
      </div>

      <!-- Right: accordion -->
      <div id="faq-list">
        {faqs.map((faq, i) => (
          <div class={`faq-item ${i === 0 ? 'open' : ''}`} data-index={i}>
            <button class="faq-trigger">
              <span>{faq.q}</span>
              <span class="faq-icon">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
                  <path d="M12 5v14M5 12h14"/>
                </svg>
              </span>
            </button>
            <div class="faq-content">
              {faq.a}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const faqList = document.getElementById('faq-list');
  if (faqList) {
    faqList.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement).closest('.faq-trigger');
      if (!trigger) return;
      const item = trigger.closest('.faq-item');
      if (!item) return;
      const isOpen = item.classList.contains('open');
      faqList.querySelectorAll('.faq-item').forEach(el => el.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  }
</script>
