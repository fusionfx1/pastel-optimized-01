---
const redirectUrl = import.meta.env.PUBLIC_REDIRECT_URL || '${redirectUrl}';

const steps = [
  {
    num: '01',
    title: 'See your plan options in 60 seconds',
    desc: 'Enter a few basic details and Scratchpay\'s proprietary technology returns your available payment plan options in under a minute — using a soft inquiry that never touches your credit score.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    accent: 'hsl(193 46% 44%)',
    accentBg: 'hsl(193 46% 60% / 0.12)',
  },
  {
    num: '02',
    title: 'Compare plans — pick what fits your budget',
    desc: 'Review your plan options side by side. See the monthly payment, total cost, and APR for each before you choose. Including 0% APR promotional options for qualified applicants.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    accent: 'hsl(338 55% 60%)',
    accentBg: 'hsl(338 70% 91% / 0.5)',
  },
  {
    num: '03',
    title: 'Confirm at the clinic — paperless',
    desc: 'Scratchpay integrates directly with your veterinary practice\'s system. No printing, no branch visits. Confirm your plan digitally from any device — at the clinic or from the waiting room.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
    accent: 'hsl(130 42% 48%)',
    accentBg: 'hsl(130 42% 82% / 0.3)',
  },
  {
    num: '04',
    title: 'Direct your attention back to your pet',
    desc: 'The financial decision is made. You know the amount, the term, and the monthly payment. It becomes a fixed line in your budget — and your pet gets the care they need, today.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
    accent: 'hsl(193 46% 44%)',
    accentBg: 'hsl(193 46% 60% / 0.12)',
  },
];
---

<section id="how-it-works" class="py-20 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-16">
      <span class="section-label">The Intelligent Way to Pay for Vet Care</span>
      <h2 class="section-title max-w-xl mx-auto">How Scratchpay Works</h2>
      <p class="text-foreground/70 text-base max-w-lg mx-auto">
        Veterinary financing built for how emergencies actually work — fast, transparent, and designed around your budget, not a credit committee.
      </p>
    </div>

    <!-- Steps grid -->
    <div class="grid md:grid-cols-4 gap-4 relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-[2.75rem] left-[12.5%] right-[12.5%] h-px pointer-events-none"
        style="background: linear-gradient(90deg, transparent, hsl(var(--border)), hsl(var(--border)), transparent);"></div>

      {steps.map((step, i) => (
        <div class={`premium-card p-6 flex flex-col gap-5 relative reveal${i === 1 ? ' reveal-d1' : i === 2 ? ' reveal-d2' : i === 3 ? ' reveal-d3' : ''}`}>
          <!-- Step number -->
          <div class="flex items-center justify-between">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
              style={`background: ${step.accentBg}; color: ${step.accent};`}
              set:html={step.icon}
            />
            <span class="font-mono text-xs font-semibold tracking-widest"
              style={`color: ${step.accent}; opacity: 0.5;`}>{step.num}</span>
          </div>

          <div>
            <h3 class="font-display font-bold text-foreground text-base mb-2">{step.title}</h3>
            <p class="text-foreground/70 text-sm leading-relaxed">{step.desc}</p>
          </div>

          {i < 3 && (
            <div class="md:hidden h-px -mx-6 mt-auto" style="background: hsl(var(--border));"></div>
          )}
        </div>
      ))}
    </div>

    <!-- Bottom CTA strip -->
    <div class="mt-10 glass-card p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div>
        <p class="font-display font-bold text-foreground text-base">See your plan options before you commit to anything</p>
        <p class="text-foreground/70 text-sm">Takes 60 seconds. Soft inquiry only — zero impact to your credit score.</p>
      </div>
      <a href={redirectUrl} class="btn-primary flex-shrink-0">
        Start My 60-Second Check — It's Free
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
