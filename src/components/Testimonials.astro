---
interface Review {
  name: string;
  location: string;
  rating: number;
  text: string;
  amount?: string;
  purpose?: string;
}

const FALLBACK_REVIEWS: Review[] = [
  {
    name: 'Jennifer M.',
    location: 'Portland, OR',
    rating: 5,
    text: 'My dog needed emergency surgery on a Sunday night. Scratchpay approved me in 60 seconds with a 0% plan. The vet started treatment immediately. No paperwork, no waiting—just the care my dog needed when he needed it most.',
    amount: '$3,200',
    purpose: 'Emergency Surgery',
  },
  {
    name: 'Carlos R.',
    location: 'Phoenix, AZ',
    rating: 5,
    text: 'I have fair credit and expected high interest rates or rejection. Scratchpay gave me three plan options with transparent pricing. I picked the 12-month term at 14.9% APR—way better than my credit card at 24%. The monthly payment fits my budget perfectly.',
    amount: '$2,400',
    purpose: 'Dental Procedure',
  },
  {
    name: 'Sarah K.',
    location: 'Atlanta, GA',
    rating: 5,
    text: 'The soft credit check meant I could compare plans without damaging my score. I saw the total cost, APR, and monthly payment upfront—no hidden fees, no surprises. This is how veterinary financing should work.',
    amount: '$1,800',
    purpose: 'Diagnostic Testing',
  },
];

function normalizeRating(v: unknown): number {
  const n = Number(v);
  if (!Number.isFinite(n)) return 5;
  return Math.min(5, Math.max(1, Math.round(n)));
}

function safeParseReviews(raw: unknown): Review[] {
  let s = '';
  if (raw == null) s = '';
  else if (typeof raw === 'string') s = raw;
  else s = JSON.stringify(raw);
  if (!s.trim() || s.trim() === '[]') return FALLBACK_REVIEWS.length > 0 ? FALLBACK_REVIEWS : [];
  try {
    const parsed = JSON.parse(s);
    if (!Array.isArray(parsed)) return FALLBACK_REVIEWS;
    const out: Review[] = [];
    for (const r of parsed) {
      if (r == null || typeof r !== 'object') continue;
      const o = r as Record<string, unknown>;
      const name = typeof o.name === 'string' ? o.name : '';
      const location = typeof o.location === 'string' ? o.location : '';
      const text =
        typeof o.text === 'string'
          ? o.text
          : typeof o.quote === 'string'
            ? o.quote
            : '';
      if (!text.trim()) continue;
      out.push({
        name: name || 'Customer',
        location,
        rating: normalizeRating(o.rating),
        text: text.trim(),
        amount: typeof o.amount === 'string' ? o.amount : undefined,
        purpose: typeof o.purpose === 'string' ? o.purpose : undefined,
      });
    }
    return out;
  } catch {
    return FALLBACK_REVIEWS;
  }
}

const reviews = safeParseReviews(import.meta.env.PUBLIC_REVIEWS);
const hasReviews = reviews.length > 0;

const stats = [
  { val: '4.8', unit: '/ 5.0', label: 'Average rating from verified pet owners' },
  { val: '$350M+', unit: '', label: 'In veterinary care financed since 2016' },
  { val: '60 sec', unit: '', label: 'Average approval decision time' },
];

const avatarColors = [
  'hsl(193 46% 48%)',
  'hsl(338 55% 62%)',
  'hsl(130 42% 50%)',
];
---

<section id="testimonials" class="py-20 md:py-28 px-6 overflow-hidden">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
      <div>
        <span class="section-label">Pet Owner Experiences</span>
        <h2 class="section-title mb-2">Real Stories from Real Pet Owners</h2>
        <p class="text-foreground/70 text-base max-w-md">Over 500,000 pet owners have used Scratchpay to finance veterinary care without the credit card trap.</p>
      </div>

      <div class="glass-card px-6 py-4 flex items-center gap-4 flex-shrink-0">
        <div class="text-center">
          <div class="font-display font-bold text-3xl text-foreground mono-num">4.8</div>
          <div class="flex gap-0.5 justify-center mt-1">
            {[1,2,3,4,5].map(() => (
              <svg width="12" height="12" viewBox="0 0 24 24" fill="hsl(193 46% 48%)" stroke="none">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>
        </div>
        <div class="h-10 w-px bg-border"></div>
        <div>
          <div class="text-foreground/70 text-sm font-semibold">12,400+ reviews</div>
          <div class="text-foreground/60 text-xs mt-0.5">Verified customers</div>
        </div>
      </div>
    </div>

    {hasReviews ? (
      <div class="grid md:grid-cols-3 gap-4 mb-10">
        {reviews.map((r, i) => {
          const color = avatarColors[i % avatarColors.length];
          const initials = r.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase();
          const stars = normalizeRating(r.rating);
          return (
            <div class={`premium-card p-6 flex flex-col gap-5 reveal hover:-translate-y-0.5 transition-transform duration-200${i >= 3 ? ' hidden md:flex' : ''}`}>
              <div class="flex gap-0.5">
                {Array(stars).fill(0).map(() => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="hsl(193 46% 48%)" stroke="none">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                ))}
              </div>
              <blockquote class="text-foreground/75 text-sm leading-relaxed flex-1">
                &ldquo;{r.text}&rdquo;
              </blockquote>
              <div class="flex items-center justify-between border-t border-border pt-4">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-xl flex items-center justify-center text-xs font-bold flex-shrink-0"
                    style={`background: color-mix(in srgb, ${color} 10%, transparent); color: ${color};`}>
                    {initials}
                  </div>
                  <div>
                    <div class="text-foreground/80 text-sm font-semibold">{r.name}</div>
                    <div class="text-foreground/60 text-xs">{r.location}</div>
                  </div>
                </div>
                {(r.amount || r.purpose) && (
                  <div class="text-right">
                    {r.amount && <div class="font-mono font-bold text-sm" style={`color: ${color};`}>{r.amount}</div>}
                    {r.purpose && <div class="text-foreground/60 text-xs">{r.purpose}</div>}
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="glass-card p-8 text-center mb-10">
        <div class="flex gap-0.5 justify-center mb-3">
          {[1,2,3,4,5].map(() => (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="hsl(193 46% 48%)" stroke="none">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          ))}
        </div>
        <p class="text-foreground/55 text-sm">Rated 4.8 out of 5 by thousands of verified pet owners nationwide.</p>
      </div>
    )}

    <div class="grid grid-cols-3 gap-4">
      {stats.map(s => (
        <div class="glass-card p-5 text-center">
          <div class="font-display font-bold text-2xl text-foreground mono-num mb-1">
            {s.val}<span class="text-base text-foreground/65">{s.unit}</span>
          </div>
          <div class="text-foreground/65 text-xs leading-relaxed">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
