PUBLIC_REVIEWS=[{"name":"Marcus T.","location":"Austin, TX","rating":5,"text":"Applied on a Tuesday morning and had the money in my account by Wednesday afternoon. The whole process was completely online and took maybe 15 minutes. Fixed rate, no surprises on my statement.","amount":"\$4,500","purpose":"Debt consolidation"},{"name":"Priya S.","location":"Chicago, IL","rating":5,"text":"I was nervous about applying because my credit isn't perfect, but I was approved the same day. The payment calculator on the site helped me pick a term that actually fits my budget.","amount":"\$2,000","purpose":"Car repairs"},{"name":"James R.","location":"Atlanta, GA","rating":4,"text":"Straightforward application and honest disclosures — I knew exactly what I'd owe before I signed anything. Customer support answered my question within the hour. Would recommend.","amount":"\$3,200","purpose":"Home improvement"}]
